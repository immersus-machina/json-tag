  "author": "immersus-machina",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/immersus-machina/json-tag"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "vitest": "^3.0.0"
  }
