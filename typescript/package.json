{
  "name": "@immersus-machina/json-tag",
  "version": "0.1.0",
  "description": "Cross-language JSON type tagging using #type",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
